# OpenAI API key for LLM extraction (leave blank to use mock extractor)
OPENAI_API_KEY=

# Model to use for extraction
OPENAI_MODEL=gpt-4o

# Data directory (default: ./data)
DATA_DIR=./data

# Confidence threshold below which fields are flagged for review (0.0-1.0)
CONFIDENCE_THRESHOLD=0.7

# Logging level
LOG_LEVEL=INFO

# FastAPI host/port
API_HOST=0.0.0.0
API_PORT=8000
