# ---- LLM Provider: Groq (free, no credit card required) ----
# 1. Go to console.groq.com and create a free account
# 2. Generate an API key from the dashboard
# 3. Paste it below
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxx
LLM_MODEL=llama-3.3-70b-versatile

# Optional: Gemini
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your_gemini_key_here
# LLM_MODEL=gemini-2.0-flash

# Optional: local Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# ---- General ----
DATA_DIR=./data
CONFIDENCE_THRESHOLD=0.7
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ---- Optional Carrier Billing APIs (primary invoice ingestion path) ----
FEDEX_BILLING_API_BASE_URL=
FEDEX_BILLING_API_KEY=
UPS_BILLING_API_BASE_URL=
UPS_BILLING_API_KEY=
