# ---- LLM Provider (default: Gemini) ----
# 1) Create a free API key: https://aistudio.google.com/apikey
# 2) Paste it below in LLM_API_KEY

LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash

# Optional: local Ollama (no API key needed)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# Optional: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o

# Optional: Groq (free tier)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your-key-here
# LLM_MODEL=llama-3.1-70b-versatile

# ---- General ----
DATA_DIR=./data
CONFIDENCE_THRESHOLD=0.7
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
